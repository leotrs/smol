% braiid.sty — LaTeX styling for RSM documents.
%
% Mirrors braiid.typ / braiid.css: same colors, spacing, and visual language.
% Used alongside braiid.lua (Pandoc Lua filter).

\NeedsTeXFormat{LaTeX2e}
\ProvidesPackage{braiid}[2026/03/28 Braiid styling for RSM]

\RequirePackage{amsthm}
\RequirePackage{xcolor}
\RequirePackage{mdframed}
\RequirePackage{hyperref}
\RequirePackage{geometry}
\RequirePackage{fancyhdr}
\RequirePackage{titlesec}
\RequirePackage{fontspec}
\RequirePackage{abstract}
\RequirePackage{caption}

% ── Colors (braiid tokens from braiid.css / braiid.typ) ────────────────────
\definecolor{braiid-gray-900}{HTML}{3C4952}
\definecolor{braiid-gray-800}{HTML}{51636F}
\definecolor{braiid-gray-700}{HTML}{5F7186}
\definecolor{braiid-gray-100}{HTML}{EDF0F2}
\definecolor{braiid-gray-75}{HTML}{F5F7F8}
\definecolor{braiid-blue-900}{HTML}{0C456E}
\definecolor{braiid-blue-700}{HTML}{0361A1}
\definecolor{braiid-blue-500}{HTML}{0E9AE9}
\definecolor{braiid-blue-400}{HTML}{38B4F8}
\definecolor{braiid-blue-300}{HTML}{7DCDFC}
\definecolor{braiid-caption}{HTML}{60B5F0}
\definecolor{braiid-border}{HTML}{D1D5DB}

% ── Page geometry (matches braiid.typ: a4, 30/30/25/25mm) ─────────────────
\geometry{a4paper, top=30mm, bottom=30mm, left=30mm, right=30mm}

% ── Fonts ──────────────────────────────────────────────────────────────────
% braiid.typ: Source Sans 3 at 11pt, Source Code Pro for mono
\IfFontExistsTF{Source Sans 3}{%
  \setmainfont{Source Sans 3}%
}{%
  \IfFontExistsTF{Source Sans Pro}{%
    \setmainfont{Source Sans Pro}%
  }{}%
}
\IfFontExistsTF{Source Code Pro}{%
  \setmonofont{Source Code Pro}[Scale=0.86]%  % 9.5/11 ≈ 0.86
}{}
\IfFontExistsTF{Montserrat}{%
  \newfontfamily\headingfont{Montserrat}[
    BoldFont={Montserrat Bold},
    FontFace={sb}{n}{Montserrat SemiBold},
    FontFace={md}{n}{Montserrat Medium},
  ]%
}{%
  \newcommand{\headingfont}{\sffamily}%
}

% ── Body text (braiid.typ: 11pt, leading 0.65em, justify, no indent) ──────
\renewcommand{\normalsize}{\fontsize{11pt}{14.3pt}\selectfont}  % 11pt × 1.3 leading
\normalsize
% Set body text color globally. Redefine 'black' before document starts so
% every package that resets to black uses gray-900 instead.
\colorlet{black}{braiid-gray-900}
\AtBeginDocument{\color{braiid-gray-900}}
\setlength{\parindent}{0pt}
\setlength{\parskip}{6pt plus 2pt minus 1pt}

% ── Hyperlinks (braiid.typ: blue-500) ─────────────────────────────────────
\hypersetup{
  colorlinks=true,
  linkcolor=braiid-blue-500,
  citecolor=braiid-blue-500,
  urlcolor=braiid-blue-500,
}


% ── Section numbering ─────────────────────────────────────────────────────
\setcounter{secnumdepth}{3}

% ── Heading styles (braiid.typ: Montserrat, #0C456E) ─────────────────────
% H1: 22pt bold
\titleformat{\section}
  {\headingfont\fontseries{b}\selectfont\fontsize{22pt}{26pt}\selectfont\color{braiid-blue-900}}
  {\thesection}{1em}{}
\titlespacing*{\section}{0pt}{1.2em}{0.4em}

% H2: 19.25pt semibold
\titleformat{\subsection}
  {\headingfont\fontseries{sb}\selectfont\fontsize{19.25pt}{23pt}\selectfont\color{braiid-blue-900}}
  {\thesubsection}{1em}{}
\titlespacing*{\subsection}{0pt}{0.96em}{0.32em}

% H3: 16.5pt medium
\titleformat{\subsubsection}
  {\headingfont\fontseries{md}\selectfont\fontsize{16.5pt}{20pt}\selectfont\color{braiid-blue-900}}
  {\thesubsubsection}{1em}{}
\titlespacing*{\subsubsection}{0pt}{0.8em}{0.24em}

% H4: 15.125pt medium
\titleformat{\paragraph}[hang]
  {\headingfont\fontseries{md}\selectfont\fontsize{15.125pt}{18pt}\selectfont\color{braiid-blue-900}}
  {\theparagraph}{1em}{}
\titlespacing*{\paragraph}{0pt}{0.64em}{0.24em}

% ── Title block (braiid.typ: 21pt bold #0C456E, centered) ────────────────
\makeatletter
\renewcommand{\maketitle}{%
  \begingroup
  \setlength{\parskip}{0pt}%
  \begin{center}%
  {\headingfont\fontseries{b}\selectfont\fontsize{21pt}{25pt}\selectfont\color{braiid-blue-900}\@title\par}%
  \vspace{0.6em}%
  {\fontsize{12pt}{15pt}\selectfont\@author\par}%
  \end{center}%
  \endgroup
  \vspace{1em}%
}
\makeatother

% ── Headers / footers (braiid.typ: page num in gray-800, no rule) ────────
\pagestyle{fancy}
\fancyhf{}
\fancyhead[R]{\small\color{braiid-gray-800}\thepage}
\fancyfoot{}
\renewcommand{\headrulewidth}{0pt}
\fancypagestyle{plain}{\fancyhf{}\fancyfoot[C]{\small\color{braiid-gray-800}\thepage}}

% ── Abstract (braiid.typ: 11pt sb heading #0C456E, 10.5pt body, 16pt indent) ─
\renewcommand{\abstractnamefont}{\headingfont\fontseries{sb}\selectfont\fontsize{11pt}{13pt}\selectfont\color{braiid-blue-900}}
\renewcommand{\abstracttextfont}{\fontsize{10.5pt}{13.5pt}\selectfont}
\setlength{\absleftindent}{16pt}
\setlength{\absrightindent}{16pt}

% ── Theorem environments (all upright body to match braiid.typ) ───────────
\theoremstyle{definition}
\newtheorem{theorem}{Theorem}[section]
\newtheorem{proposition}[theorem]{Proposition}
\newtheorem{lemma}[theorem]{Lemma}
\newtheorem{corollary}[theorem]{Corollary}
\newtheorem{definition}[theorem]{Definition}
\newtheorem{example}[theorem]{Example}
\newtheorem{exercise}[theorem]{Exercise}
\newtheorem{problem}[theorem]{Problem}
\newtheorem{porism}[theorem]{Porism}
\newtheorem{remark}[theorem]{Remark}

% ── Theorem styling (braiid.typ: 1.5pt #D1D5DB left, 6pt top/bottom, 14pt outset) ─
\mdfdefinestyle{braiid-theorem}{
  linewidth=1.5pt,
  linecolor=braiid-border,
  topline=false,
  bottomline=false,
  rightline=false,
  innertopmargin=6pt,
  innerbottommargin=6pt,
  innerrightmargin=0pt,
  innerleftmargin=14pt,
  leftmargin=-15.5pt,
  skipabove=10pt,
  skipbelow=10pt,
}

\surroundwithmdframed[style=braiid-theorem]{theorem}
\surroundwithmdframed[style=braiid-theorem]{proposition}
\surroundwithmdframed[style=braiid-theorem]{lemma}
\surroundwithmdframed[style=braiid-theorem]{corollary}
\surroundwithmdframed[style=braiid-theorem]{definition}
\surroundwithmdframed[style=braiid-theorem]{example}
\surroundwithmdframed[style=braiid-theorem]{remark}

% ── Proof styling (braiid.typ: 6pt square #0361A1) ──────────────────────
\renewcommand{\qedsymbol}{\color{braiid-blue-700}\rule{6pt}{6pt}}

% ── Figure captions (braiid.typ: 1.5pt #60B5F0 left, 10pt text) ─────────
\DeclareCaptionFormat{braiid}{\textbf{#1#2}#3}
\captionsetup{
  format=braiid,
  font={small},
  labelsep=period,
  justification=justified,
  singlelinecheck=false,
}

% ── Code blocks (braiid.typ: gray-75 bg, Source Code Pro 9.5pt) ──────────
\RequirePackage{listings}
\lstset{
  backgroundcolor=\color{braiid-gray-75},
  basicstyle=\ttfamily\fontsize{9.5pt}{12pt}\selectfont,
  frame=none,
  xleftmargin=10pt,
  xrightmargin=10pt,
  aboveskip=6pt,
  belowskip=6pt,
  breaklines=true,
}
